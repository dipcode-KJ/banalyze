---
const {
  title = "NINES DATA | Bリーグ統計ダッシュボード",
  description = "Bリーグの試合結果を収集し、勝率・得失点差・ホーム/アウェイ成績を可視化する統計サービスです。",
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-8KJ7QW5VHK"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-8KJ7QW5VHK");
    </script>
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      document.addEventListener("click", (event) => {
        const button = event.target.closest(".menuButton");
        const link = event.target.closest(".mobileDrawer a");

        if (button) {
          const isOpen = document.body.classList.toggle("drawerOpen");
          button.setAttribute("aria-expanded", String(isOpen));
        }

        if (link) {
          document.body.classList.remove("drawerOpen");
          document.querySelectorAll(".menuButton").forEach((item) => item.setAttribute("aria-expanded", "false"));
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          document.body.classList.remove("drawerOpen");
          document.querySelectorAll(".menuButton").forEach((item) => item.setAttribute("aria-expanded", "false"));
        }
      });
    </script>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }

  html {
    font-family:
      "Noto Sans JP", "Helvetica Neue", Arial, "Hiragino Kaku Gothic ProN", "Yu Gothic", Meiryo, sans-serif;
    background: #ffffff;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
  }
</style>
